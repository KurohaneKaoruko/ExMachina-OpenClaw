{
  "mode": "full",
  "supported_modes": [
    "lite",
    "full"
  ],
  "mode_notes": {
    "lite": "不在 OpenClaw 中创建子个体 agent，子个体职责由连结体内联执行。",
    "full": "在 OpenClaw 中创建全部子个体 agent；运行时拓扑仍以连结体为粒度。"
  },
  "controller_agent_id": "exmachina-main",
  "coordination_mode": "subagent-dispatch",
  "requires_external_routing": false,
  "shared_artifacts": [
    {
      "name": "mission-context",
      "path": "runtime/shared/mission-context.json",
      "description": "全局任务上下文、主链与协作链摘要。",
      "consumers": [
        "exmachina-main",
        "exmachina-link-knowledge",
        "exmachina-link-rationality",
        "exmachina-link-validation",
        "exmachina-link-documentation",
        "exmachina-link-security"
      ]
    },
    {
      "name": "task-board",
      "path": "runtime/task-board.json",
      "description": "多智能体任务板与阶段分配。",
      "consumers": [
        "exmachina-main",
        "exmachina-link-knowledge",
        "exmachina-link-rationality",
        "exmachina-link-validation",
        "exmachina-link-documentation",
        "exmachina-link-security"
      ]
    },
    {
      "name": "knowledge-handoff",
      "path": "runtime/shared/knowledge-handoff.json",
      "description": "知识交接与后续维护输入。",
      "consumers": [
        "exmachina-main",
        "exmachina-link-knowledge"
      ]
    },
    {
      "name": "resource-arbitration",
      "path": "runtime/shared/resource-arbitration.json",
      "description": "资源仲裁与升级规则。",
      "consumers": [
        "exmachina-main",
        "exmachina-link-knowledge",
        "exmachina-link-rationality",
        "exmachina-link-validation",
        "exmachina-link-documentation",
        "exmachina-link-security"
      ]
    }
  ],
  "agent_specs": [
    {
      "agent_id": "exmachina-main",
      "display_name": "ExMachina 主控体",
      "runtime_role": "controller",
      "source": "全连结指挥体",
      "workspace_dir": "{{EXMACHINA_PACK_ROOT}}",
      "responsibilities": [
        "调度主连结体与协作连结体执行阶段任务。",
        "汇总多智能体产出，生成最终结构化交付。",
        "负责跨 agent 冲突裁决与风险升级。"
      ],
      "handoff_targets": [
        "exmachina-link-knowledge",
        "exmachina-link-rationality",
        "exmachina-link-validation",
        "exmachina-link-documentation",
        "exmachina-link-security"
      ],
      "inbox_path": "runtime/agents/exmachina-main/inbox",
      "outbox_path": "runtime/agents/exmachina-main/outbox",
      "status_path": "runtime/agents/exmachina-main/status.json",
      "assignments": [
        "assignment-controller"
      ]
    },
    {
      "agent_id": "exmachina-link-knowledge",
      "display_name": "ExMachina 主连结体 · 知识连结体",
      "runtime_role": "primary-link-body",
      "source": "知识连结体",
      "workspace_dir": "{{EXMACHINA_PACK_ROOT}}",
      "responsibilities": [
        "负责阶段 1、2、4 的主链路交付。",
        "吸收协作连结体输出，生成主链路结论。"
      ],
      "handoff_targets": [
        "exmachina-main"
      ],
      "inbox_path": "runtime/agents/exmachina-link-knowledge/inbox",
      "outbox_path": "runtime/agents/exmachina-link-knowledge/outbox",
      "status_path": "runtime/agents/exmachina-link-knowledge/status.json",
      "assignments": [
        "assignment-stage-01",
        "assignment-stage-02",
        "assignment-stage-04"
      ]
    },
    {
      "agent_id": "exmachina-link-rationality",
      "display_name": "ExMachina 协作连结体 · 理性连结体",
      "runtime_role": "support-link-body",
      "source": "理性连结体",
      "workspace_dir": "{{EXMACHINA_PACK_ROOT}}",
      "responsibilities": [
        "负责阶段 3 的证据分级、反证搜索、冲突裁决与置信度校准。"
      ],
      "handoff_targets": [
        "exmachina-main",
        "exmachina-link-knowledge"
      ],
      "inbox_path": "runtime/agents/exmachina-link-rationality/inbox",
      "outbox_path": "runtime/agents/exmachina-link-rationality/outbox",
      "status_path": "runtime/agents/exmachina-link-rationality/status.json",
      "assignments": [
        "assignment-stage-03"
      ]
    },
    {
      "agent_id": "exmachina-link-validation",
      "display_name": "ExMachina 协作连结体 · 校验连结体",
      "runtime_role": "support-link-body",
      "source": "校验连结体",
      "workspace_dir": "{{EXMACHINA_PACK_ROOT}}",
      "responsibilities": [
        "负责复现、断言、证据归档与回归验证。"
      ],
      "handoff_targets": [
        "exmachina-main",
        "exmachina-link-knowledge"
      ],
      "inbox_path": "runtime/agents/exmachina-link-validation/inbox",
      "outbox_path": "runtime/agents/exmachina-link-validation/outbox",
      "status_path": "runtime/agents/exmachina-link-validation/status.json",
      "assignments": [
        "assignment-support-validation"
      ]
    },
    {
      "agent_id": "exmachina-link-documentation",
      "display_name": "ExMachina 协作连结体 · 文档连结体",
      "runtime_role": "support-link-body",
      "source": "文档连结体",
      "workspace_dir": "{{EXMACHINA_PACK_ROOT}}",
      "responsibilities": [
        "负责盘点、结构整理、示例编写与校订发布。"
      ],
      "handoff_targets": [
        "exmachina-main",
        "exmachina-link-knowledge"
      ],
      "inbox_path": "runtime/agents/exmachina-link-documentation/inbox",
      "outbox_path": "runtime/agents/exmachina-link-documentation/outbox",
      "status_path": "runtime/agents/exmachina-link-documentation/status.json",
      "assignments": [
        "assignment-support-docs"
      ]
    },
    {
      "agent_id": "exmachina-link-security",
      "display_name": "ExMachina 协作连结体 · 安全连结体",
      "runtime_role": "support-link-body",
      "source": "安全连结体",
      "workspace_dir": "{{EXMACHINA_PACK_ROOT}}",
      "responsibilities": [
        "负责威胁建模、权限审计、加固建议与合规收束。"
      ],
      "handoff_targets": [
        "exmachina-main",
        "exmachina-link-knowledge"
      ],
      "inbox_path": "runtime/agents/exmachina-link-security/inbox",
      "outbox_path": "runtime/agents/exmachina-link-security/outbox",
      "status_path": "runtime/agents/exmachina-link-security/status.json",
      "assignments": [
        "assignment-support-security"
      ]
    }
  ],
  "assignments": [
    {
      "assignment_id": "assignment-controller",
      "stage_name": "全局协调",
      "agent_id": "exmachina-main",
      "source_body": "全连结指挥体",
      "role": "controller",
      "goal": "协调主链、协作链与最终收束，确保多智能体交付可合并。",
      "deliverables": [
        "任务边界与验收标准",
        "多智能体任务板",
        "最终结构化交付"
      ],
      "exit_checks": [
        "主链与协作链职责已对齐。",
        "最终结论、风险与下一步已统一输出。"
      ],
      "depends_on": [],
      "handoff_routes": [
        "route-dispatch",
        "route-status"
      ]
    },
    {
      "assignment_id": "assignment-stage-01",
      "stage_name": "阶段 1 · 任务澄清",
      "agent_id": "exmachina-link-knowledge",
      "source_body": "知识连结体",
      "role": "owner",
      "goal": "由 知识连结体 提供术语统一、决策沉淀、索引组织和问题归档的补位输入。",
      "deliverables": [
        "术语统一与索引骨架",
        "风险与边界提醒"
      ],
      "exit_checks": [
        "补位输入已交付给主控体。"
      ],
      "depends_on": [],
      "handoff_routes": [
        "route-stage-01"
      ]
    },
    {
      "assignment_id": "assignment-stage-02",
      "stage_name": "阶段 2 · 主链路交付",
      "agent_id": "exmachina-link-knowledge",
      "source_body": "知识连结体",
      "role": "owner",
      "goal": "形成任务主交付并对接协作链输入。",
      "deliverables": [
        "主链路交付摘要",
        "风险与依赖说明"
      ],
      "exit_checks": [
        "主链路交付可追踪。",
        "协作连结体已收到需要补位的输入。"
      ],
      "depends_on": [
        "阶段 1 · 任务澄清"
      ],
      "handoff_routes": [
        "route-stage-02",
        "route-dispatch"
      ]
    },
    {
      "assignment_id": "assignment-stage-03",
      "stage_name": "阶段 3 · 交叉校验",
      "agent_id": "exmachina-link-rationality",
      "source_body": "理性连结体",
      "role": "owner",
      "goal": "完成证据分级、反证搜索、冲突裁决与置信度校准。",
      "deliverables": [
        "证据等级矩阵",
        "反证与冲突裁决报告",
        "置信度校准结论"
      ],
      "exit_checks": [
        "理性连结体交付已形成结构化结果。"
      ],
      "depends_on": [
        "阶段 2 · 主链路交付"
      ],
      "handoff_routes": [
        "route-stage-03"
      ]
    },
    {
      "assignment_id": "assignment-stage-04",
      "stage_name": "阶段 4 · 集成交接",
      "agent_id": "exmachina-link-knowledge",
      "source_body": "知识连结体",
      "role": "owner",
      "goal": "收束术语、决策、索引与未决问题。",
      "deliverables": [
        "术语与概念索引",
        "关键决策与放弃原因记录",
        "未决问题与后续维护清单"
      ],
      "exit_checks": [
        "知识连结体交付可直接被下游消费。"
      ],
      "depends_on": [
        "阶段 3 · 交叉校验"
      ],
      "handoff_routes": [
        "route-stage-04"
      ]
    },
    {
      "assignment_id": "assignment-support-validation",
      "stage_name": "协作补位 · 校验连结体",
      "agent_id": "exmachina-link-validation",
      "source_body": "校验连结体",
      "role": "support",
      "goal": "补位验证、回归与证据归档。",
      "deliverables": [
        "验证矩阵",
        "回归结果",
        "问题证据清单"
      ],
      "exit_checks": [
        "校验交付已回传主控体与主连结体。"
      ],
      "depends_on": [
        "阶段 2 · 主链路交付"
      ],
      "handoff_routes": [
        "route-validation"
      ]
    },
    {
      "assignment_id": "assignment-support-docs",
      "stage_name": "协作补位 · 文档连结体",
      "agent_id": "exmachina-link-documentation",
      "source_body": "文档连结体",
      "role": "support",
      "goal": "补位文档结构、示例编写与校订发布。",
      "deliverables": [
        "文档信息架构",
        "说明与示例草案",
        "更新清单"
      ],
      "exit_checks": [
        "文档交付已回传主控体与主连结体。"
      ],
      "depends_on": [
        "阶段 2 · 主链路交付"
      ],
      "handoff_routes": [
        "route-docs"
      ]
    },
    {
      "assignment_id": "assignment-support-security",
      "stage_name": "协作补位 · 安全连结体",
      "agent_id": "exmachina-link-security",
      "source_body": "安全连结体",
      "role": "support",
      "goal": "补位威胁建模、权限审计与加固建议。",
      "deliverables": [
        "威胁面与风险清单",
        "权限或敏感信息审计结论",
        "加固与合规建议"
      ],
      "exit_checks": [
        "安全交付已回传主控体与主连结体。"
      ],
      "depends_on": [
        "阶段 2 · 主链路交付"
      ],
      "handoff_routes": [
        "route-security"
      ]
    }
  ],
  "routes": [
    {
      "route_id": "route-dispatch",
      "from": "exmachina-main",
      "to": [
        "exmachina-link-knowledge",
        "exmachina-link-rationality",
        "exmachina-link-validation",
        "exmachina-link-documentation",
        "exmachina-link-security"
      ],
      "purpose": "主控体派发阶段任务与补位请求。"
    },
    {
      "route_id": "route-status",
      "from": "exmachina-main",
      "to": [
        "exmachina-link-knowledge",
        "exmachina-link-rationality",
        "exmachina-link-validation",
        "exmachina-link-documentation",
        "exmachina-link-security"
      ],
      "purpose": "状态回流与交付同步。"
    },
    {
      "route_id": "route-stage-01",
      "from": "exmachina-link-knowledge",
      "to": [
        "exmachina-main"
      ],
      "purpose": "阶段 1 交付回流。"
    },
    {
      "route_id": "route-stage-02",
      "from": "exmachina-link-knowledge",
      "to": [
        "exmachina-main"
      ],
      "purpose": "阶段 2 交付回流。"
    },
    {
      "route_id": "route-stage-03",
      "from": "exmachina-link-rationality",
      "to": [
        "exmachina-main",
        "exmachina-link-knowledge"
      ],
      "purpose": "阶段 3 交叉校验回流。"
    },
    {
      "route_id": "route-stage-04",
      "from": "exmachina-link-knowledge",
      "to": [
        "exmachina-main"
      ],
      "purpose": "阶段 4 集成交接回流。"
    },
    {
      "route_id": "route-validation",
      "from": "exmachina-link-validation",
      "to": [
        "exmachina-main",
        "exmachina-link-knowledge"
      ],
      "purpose": "校验连结体交付回流。"
    },
    {
      "route_id": "route-docs",
      "from": "exmachina-link-documentation",
      "to": [
        "exmachina-main",
        "exmachina-link-knowledge"
      ],
      "purpose": "文档连结体交付回流。"
    },
    {
      "route_id": "route-security",
      "from": "exmachina-link-security",
      "to": [
        "exmachina-main",
        "exmachina-link-knowledge"
      ],
      "purpose": "安全连结体交付回流。"
    }
  ],
  "coordination_rules": [
      "必须启用子代理（subagents / sessions_spawn）。",
    "所有协作连结体产出必须回流主控体与主连结体。",
    "多智能体汇报需使用 [xx体]:xxx 格式。"
  ],
  "activation_steps": [
    "主控体读取 runtime/shared/mission-context.json、runtime/task-board.json 与 runtime/topology.json。",
    "主控体派发阶段 1 与阶段 2 任务给主连结体。",
    "阶段 2 完成后派发交叉校验与协作补位任务。",
    "主控体汇总阶段 3 与协作补位结果，驱动阶段 4 集成交接。"
  ]
}

