{
  "mode": "full",
  "template_variables": {
    "OPENCLAW_INSTALL_LANGUAGE": {
      "default": "en-US"
    },
    "OPENCLAW_CONDUCTOR_NAME": {
      "default": "ExMachina Controller"
    },
    "EXMACHINA_PACK_ROOT": {
      "default": "{{EXMACHINA_PACK_ROOT}}"
    }
  },
  "settings_patch": {
    "agents": {
      "defaults": {
        "subagents": {
          "maxSpawnDepth": 2
        }
      },
      "list": [
        {
          "id": "exmachina-main",
          "name": "{{OPENCLAW_CONDUCTOR_NAME}}",
          "default": true,
          "workspace": "{{EXMACHINA_PACK_ROOT}}",
          "identity": {
            "theme": "Install language: {{OPENCLAW_INSTALL_LANGUAGE}}"
          }
        },
        {
          "id": "exmachina-link-security",
          "name": "ExMachina Support 4",
          "workspace": "{{EXMACHINA_PACK_ROOT}}",
          "identity": {
            "theme": "New security body"
          }
        }
      ]
    }
  }
}

